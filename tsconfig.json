{
  "compilerOptions": {
    "target": "es2022",                /* Or es2021, es6, etc. */
    "experimentalDecorators": true,    /* Enables experimental support for legacy decorators */
    "emitDecoratorMetadata": true,     /* Enables experimental support for emitting type metadata */
    "strictPropertyInitialization": false, /* Recommended for TypeORM entities (! fields) */
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "prisma.config.ts"
  ],
  "exclude": ["node_modules"]
}
